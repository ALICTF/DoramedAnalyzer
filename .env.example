# Copy this file to .env and fill in real values.
# Do not commit .env. It is already ignored by .gitignore.

# Required for AI-powered vision/classification/parsing fallback.
GAPGPT_API_KEY=your_gapgpt_api_key_here

# GapGPT OpenAI-compatible endpoint.
GAPGPT_BASE_URL=https://api.gapgpt.app/v1

# Model selection.
DSTAND_TEXT_MODEL=qwen3-235b-a22b
DSTAND_VISION_MODEL=gemini-2.5-flash-lite
DSTAND_VISION_FALLBACK_MODEL=gemini-3.1-flash-lite
DSTAND_VISION_PREMIUM_MODEL=gemini-3.5-flash

# Parser behavior.
DSTAND_MAX_VISION_PAGES=5
DSTAND_PDF_SAMPLE_PAGES=5
DSTAND_PDF_RENDER_DPI=150
DSTAND_OCR_DPI=200
DSTAND_OCR_ENABLED=true
DSTAND_LLM_TEMPERATURE=0.0
DSTAND_CLASSIFICATION_MIN_CONFIDENCE=0.6

# Logging.
DSTAND_LOG_LEVEL=INFO

# pricing override format:
model:input_price_per_1m:output_price_per_1m;
model2:input_price_per_1m:output_price_per_1m
DSTAND_MODEL_PRICING=qwen3-235b-a22b:0.16:0.48
